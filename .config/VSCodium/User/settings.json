/*
Install the following extensions:
vscodevim.vim - https://open-vsx.org/vscode/item?itemName=llvm-vs-code-extensions.vscode-clangd

lsp for C:
* Uncomment required lines given plataform
llvm-vs-code-extensions.vscode-clangd - https://open-vsx.org/vscode/item?itemName=llvm-vs-code-extensions.vscode-clangd

for debbuging C, install the extension and have lldb-dap installed on your machine
* Uncomment required lines given plataform
llvm-vs-code-extensions.lldb-dap - https://open-vsx.org/extension/llvm-vs-code-extensions/lldb-dap
*/
{
    "editor.tabSize": 2,

    // LSP SETUP /////////////////////////////////////

    // uncomment the required one given plataform

    //for linux flatpak
    // "clangd.path": "${env:HOME}/.var/app/com.vscodium.codium/config/VSCodium/User/globalStorage/llvm-vs-code-extensions.vscode-clangd/install/21.1.8/clangd_21.1.8/bin/clangd",

    //for linux
    // "clangd.path": "clangd",

    //for windows in the MSYS2 UCRT64 environment
    // "clangd.path": "C:\\msys64\\ucrt64\\bin\\clangd.exe",

    // LSP SETUP /////////////////////////////////////

    // DAP SETUP /////////////////////////////////////

    // uncomment the required one given plataform

    //for windows in the MSYS2 UCRT64 environment
    // "lldb-dap.executable-path": "C:/msys64/ucrt64/bin/lldb-dap.exe",
    // DAP SETUP /////////////////////////////////////

    "C_Cpp.intelliSenseEngine": "disabled",
    "vim.useSystemClipboard": true,
    "editor.fontFamily": "'MesloLGS NF Regular'",

    "vim.leader": "<space>",
    "vim.normalModeKeyBindingsNonRecursive": [
        //debbuger
        { "before": ["<leader>", "d", "s"], "commands": ["workbench.action.debug.start"] },
        { "before": ["<leader>", "d", "c"], "commands": [ "workbench.action.debug.continue"] },
        { "before": ["<leader>","d","o"], "commands": ["workbench.action.debug.stepOver"] },
        { "before": ["<leader>","d","i"], "commands": ["workbench.action.debug.stepInto"] },
        { "before": [ "<leader>","d", "u"], "commands": ["workbench.action.debug.stepOut"] },
        { "before": ["<leader>","d","b"], "commands": ["editor.debug.action.toggleBreakpoint"] },
        { "before": ["<leader>","d","d"], "commands": ["workbench.action.debug.stop"] },
        { "before": ["<leader>","d","p"], "commands": ["workbench.action.debug.pause"] },
        //buffers
        {"before": ["<leader>","b"], "commands": ["workbench.action.showAllEditors"] },
        {"before": ["<leader>","b", "n"], "commands": ["workbench.action.nextEditor"] },
        {"before": ["<leader>","b", "b"], "commands": ["workbench.action.previousEditor"] },
        {"before": ["<leader>", "c"], "commands": ["workbench.action.closeActiveEditor"] },
        {"before": ["<leader>", "b", "h"], "commands": ["workbench.action.closeEditorsToTheLeft"] },
        {"before": ["<leader>", "b", "l"], "commands": ["workbench.action.closeEditorsToTheRight"]},
        {"before": ["<leader>", "w"], "commands": ["workbench.action.files.save"] },
        //navigation
        {"before": ["<leader>","e"],  "commands": ["workbench.action.toggleSidebarVisibility"] },
        //file finder
        {"before": ["<leader>","f"], "commands": ["workbench.action.quickOpen"] },
        //searching
        {"before": ["<leader>","s", "t"], "commands": ["workbench.action.findInFiles"] },
        //lsp
        {"before": ["<leader>","l", "j"], "commands": ["editor.action.marker.next"] },
        {"before": ["<leader>","l", "k"], "commands": ["editor.action.marker.prev"] },
        {"before": ["<leader>","l", "f"], "commands": ["editor.action.formatDocument"], "when": "editorTextFocus && !editorReadonly" },
        //commenting
        {"before": ["<leader>","/"], "commands": ["editor.action.commentLine"] },
    ],
    "vim.visualModeKeyBindings": [
        { "before": ["<leader>", "/"], "commands": ["editor.action.commentLine"], "when": "editorTextFocus && !editorReadonly" },
    ],

    // UI SETUP ////////////////////////////////////////
    //updates the default layout
    "window.commandCenter": false,
    "workbench.activityBar.location": "bottom",
    "workbench.layoutControl.enabled": false,
    "window.customTitleBarVisibility": "windowed",
    //highlights vim searchs made by "/"
    "vim.hlsearch": true,
    "vim.searchHighlightColor": "#fffa65",
    "vim.searchHighlightTextColor": "#000000",
    //removes default background when hovering text
    "workbench.colorCustomizations": {
        "editor.hoverHighlightBackground": "#00000000",
        "editor.wordHighlightBackground": "#00000000",
        "editor.wordHighlightStrongBackground": "#00000000"
    },
    // UI SETUP ////////////////////////////////////////

    "[c]": { "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd" },
    "terminal.integrated.profiles.windows": {
        "PowerShell": {
            "source": "PowerShell",
            "icon": "terminal-powershell",
            "path": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe"
        },
        "Command Prompt": {
            "path": [
                "${env:windir}\\Sysnative\\cmd.exe",
                "${env:windir}\\System32\\cmd.exe"
            ],
            "args": [],
            "icon": "terminal-cmd"
        },
        "Git Bash": {
            "source": "Git Bash",
            "icon": "terminal-git-bash"
        },
        "MSYS2 UCRT": {
            "path": "C:\\Windows\\system32\\cmd.exe",
            "args": [
                "/c",
                "C:\\msys64\\msys2_shell.cmd -defterm -here -no-start -ucrt64"
            ]
        }
    },
    "terminal.integrated.defaultProfile.windows": "MSYS2 UCRT"
}